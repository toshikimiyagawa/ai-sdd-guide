{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SDD Verification Evidence",
  "description": "verify フェーズの検証証跡 (specs/<feature>/evidence.json)。",
  "type": "object",
  "required": ["feature", "commit_sha", "entries"],
  "additionalProperties": false,
  "properties": {
    "feature": {
      "type": "string",
      "description": "Feature slug"
    },
    "commit_sha": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{40}$",
      "description": "40 桁 hex commit SHA"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "description": "検証コマンド証跡エントリ",
      "items": {
        "type": "object",
        "required": ["command_type", "command", "result", "test_count"],
        "additionalProperties": false,
        "properties": {
          "command_type": {
            "type": "string",
            "enum": ["test", "lint", "build", "other"],
            "description": "実行した command の種別"
          },
          "command": {
            "type": "string",
            "description": "実行した command"
          },
          "result": {
            "type": "string",
            "description": "実行結果の要約"
          },
          "test_count": {
            "type": ["integer", "null"],
            "description": "test command の test 件数。test 以外は null。"
          }
        },
        "if": {
          "properties": {
            "command_type": {"const": "test"}
          }
        },
        "then": {
          "properties": {
            "test_count": {"type": "integer"}
          }
        },
        "else": {
          "properties": {
            "test_count": {"type": "null"}
          }
        }
      }
    }
  }
}
